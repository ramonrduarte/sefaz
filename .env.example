# Copie este arquivo para .env e preencha os valores
# No Portainer, configure estas variáveis em: Stack → Environment Variables

# ── Pasta de rede compartilhada (SMB/CIFS) ──────────────────────────
# Caminho UNC do compartilhamento de rede
SHARE_PATH=//192.168.1.10/notas

# Credenciais de acesso ao compartilhamento
SHARE_USER=seu_usuario
SHARE_PASS=sua_senha

# Domínio Windows (deixe vazio se não usar domínio)
SHARE_DOMAIN=

# ── Configurações gerais ─────────────────────────────────────────────
# Porta que o container vai expor
PORT=8080

# Fuso horário
TZ=America/Sao_Paulo
